{
  "name": "higgtable",
  "version": "0.1.1",
  "description": "Airtable file renaming tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "release": "electron-builder --mac --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "build": {
    "appId": "com.internal.higgtable",
    "productName": "HiggTable",
    "files": [
      "**/*",
      "!config.js",
      "!docs/**",
      "!tests/**",
      "!*.md"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "CYBEROUT-me",
      "repo": "higgtable",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "image-size": "^2.0.2"
  }
}
